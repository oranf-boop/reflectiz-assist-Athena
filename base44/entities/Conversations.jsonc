{
  "name": "Conversations",
  "type": "object",
  "properties": {
    "sessionId": {
      "type": "string",
      "title": "Session ID"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "title": "Timestamp"
    },
    "geo": {
      "type": "string",
      "title": "Geo"
    },
    "referralSource": {
      "type": "string",
      "title": "Referral Source"
    },
    "pagesViewed": {
      "type": "string",
      "title": "Pages Viewed"
    },
    "intentClassification": {
      "type": "string",
      "title": "Intent Classification",
      "enum": [
        "PCI_COMPLIANCE",
        "MAGECART_PREVENTION",
        "PRIVACY_GDPR",
        "SUPPLY_CHAIN",
        "TOOL_EVALUATION",
        "GENERAL_AWARENESS"
      ]
    },
    "conversationTranscript": {
      "type": "string",
      "title": "Conversation Transcript",
      "format": "textarea"
    },
    "ctaReached": {
      "type": "boolean",
      "title": "CTA Reached"
    },
    "language": {
      "type": "string",
      "title": "Language"
    },
    "conversationTurns": {
      "type": "number",
      "title": "Conversation Turns"
    },
    "linksClicked": {
      "type": "number",
      "title": "Links Clicked"
    },
    "ctaClicked": {
      "type": "boolean",
      "title": "CTA Clicked"
    },
    "conversationOutcome": {
      "type": "string",
      "title": "Conversation Outcome",
      "enum": [
        "CONVERTED",
        "ENGAGED",
        "DROPPED",
        "BOUNCED"
      ]
    },
    "sessionDuration": {
      "type": "number",
      "title": "Session Duration (seconds)"
    },
    "lastMessageRole": {
      "type": "string",
      "title": "Last Message Role",
      "enum": [
        "user",
        "assistant"
      ]
    },
    "isTrainingData": {
      "type": "boolean",
      "title": "Is Training Data"
    }
  },
  "required": []
}